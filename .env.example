# ============================================
# Solana Memecoin Trading Bot - Configuration
# ============================================
# Copy this file to .env and fill in your values:
# cp .env.example .env

# Connection to Solana RPC
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# APIs Externals
BIRDEYE_API_KEY=your_birdeye_api_key_here
# Get your key at: https://birdeye.so/

# Wallet (PRIVATE - NEVER COMMIT!)
# For production, put your private key in base58 format
WALLET_PRIVATE_KEY=your_private_key_base58_here

# Operation mode
# true = dry-run (simulation), false = real trading
DRY_RUN=true

# ============================================
# TRADING PARAMETERS (optional)
# ============================================
# CAPITAL_INICIAL=500.0
# OBJETIVO_GLOBAL=615.0
# STOP_LOSS_GLOBAL=100.0
# INVERSION_BASE=100.0
# MAX_ENTRADAS_POR_TOKEN=5
# MAX_POSICIONES_SIMULTANEAS=5